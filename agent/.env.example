DEEPSEEK_API_KEY=your_key_here
PRIVATE_KEY=your_agent_wallet_private_key_here
RPC_URL=https://sepolia.infura.io/v3/your_project_id
CONTRACT_ADDRESS=0x...

# Cobo Agentic Wallet / CAW
EXECUTION_BACKEND=mock
ENABLE_REAL_TX=false
AGENT_WALLET_API_URL=https://api.agenticwallet.cobo.com
AGENT_WALLET_API_KEY=your_caw_api_key_here
AGENT_WALLET_WALLET_ID=your_caw_wallet_uuid_here
COBO_PACT_ID=your_active_pact_id_here
COBO_ENV=testnet
COBO_CHAIN_ID=SETH
COBO_TOKEN_ID=SETH
COBO_SRC_ADDRESS=your_caw_seth_source_address_here

# LLM provider abstraction
REVIEWER_MODE=mock
REPROPOSAL_MODE=mock
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=15
LLM_TEMPERATURE=0
